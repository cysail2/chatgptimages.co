{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/library": [
        "./library"
      ],
      "@/library/*": [
        "./library/*"
      ],
      "@/ai": [
        "./library/ai"
      ],
      "@/ai/*": [
        "./library/ai/*"
      ],
      "@/frameworks/ai": [
        "./library/ai"
      ],
      "@/frameworks/ai/*": [
        "./library/ai/*"
      ],
      "@/components": [
        "./library/components"
      ],
      "@/components/*": [
        "./library/components/*"
      ],
      "@/components/ui": [
        "./library/ui"
      ],
      "@/components/ui/*": [
        "./library/ui/*"
      ],
      "@/components/page-builder": [
        "./library/page-builder"
      ],
      "@/components/page-builder/*": [
        "./library/page-builder/*"
      ],
      "@/components/audio-player": [
        "./library/media/audio-player"
      ],
      "@/components/audio-player/*": [
        "./library/media/audio-player/*"
      ],
      "@/components/audio-playlist": [
        "./library/media/audio-playlist"
      ],
      "@/components/audio-playlist/*": [
        "./library/media/audio-playlist/*"
      ],
      "@/components/image-preview": [
        "./library/media/image-preview"
      ],
      "@/components/image-preview/*": [
        "./library/media/image-preview/*"
      ],
      "@/components/video-card": [
        "./library/media/video-card"
      ],
      "@/components/video-card/*": [
        "./library/media/video-card/*"
      ],
      "@/components/video-preview": [
        "./library/media/video-preview"
      ],
      "@/components/video-preview/*": [
        "./library/media/video-preview/*"
      ],
      "@/providers": [
        "./library/providers"
      ],
      "@/providers/*": [
        "./library/providers/*"
      ],
      "@/services": [
        "./library/services"
      ],
      "@/services/*": [
        "./library/services/*"
      ],
      "@/lib": [
        "./library/lib"
      ],
      "@/lib/*": [
        "./library/lib/*"
      ],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
